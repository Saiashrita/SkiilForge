# SkillForge Environment Configuration
# Copy this to .env and fill in your values

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides (defaults shown)
# SKILLFORGE_GEMINI_MODEL=gemini-2.0-flash-exp
# SKILLFORGE_GEMINI_MODEL_PRO=gemini-2.0-pro-exp
# SKILLFORGE_STORAGE_DIR=~/.skillforge
# SKILLFORGE_PATTERN_MIN_LINES=5
# SKILLFORGE_PATTERN_MIN_FREQUENCY=2
# SKILLFORGE_DEBOUNCE_SECONDS=2.0
# SKILLFORGE_AUTO_CURSOR_RULES=true
# SKILLFORGE_VERBOSE_LOGGING=false
